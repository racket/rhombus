// 13.2.5.61 After DOCTYPE public identifier state
state after_doctype_public_identifier_state(lex)
| Char"\t" || Char"\n" || Char"\f" || Char" ":
    between_doctype_public_and_system_identifiers_state
| Char">":
    emit_current_doctype(lex)
    data_state
| Char"\"":
    parse_error(lex, #'missing_whitespace_between_doctype_public_and_system_identifiers)
    set_doctype_system_id_empty(lex)
    doctype_system_identifier_double_quoted_state
| Char"'":
    parse_error(lex, #'missing_whitespace_between_doctype_public_and_system_identifiers)
