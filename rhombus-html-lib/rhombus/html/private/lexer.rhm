// 13.2.5.66 DOCTYPE system identifier (single-quoted) state
state doctype_system_identifier_single_quoted_state(lex)
| Char"'":
    after_doctype_system_identifier_state
| Char"\0":
    parse_error(lex, #'unexpected_null_character)
    append_to_doctype_system_id(lex, REPLACEMENT_CHAR)
