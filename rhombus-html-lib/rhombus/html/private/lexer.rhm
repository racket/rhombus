    set_doctype_force_quirks(lex)
    reconsume_in(lex, bogus_doctype_state)

// 13.2.5.62 Between DOCTYPE public and system identifiers state
state between_doctype_public_and_system_identifiers_state(lex)
| Char"\t" || Char"\n" || Char"\f" || Char" ":
    between_doctype_public_and_system_identifiers_state
| Char">":
    emit_current_doctype(lex)
    data_state
| Char"\"":
    set_doctype_system_id_empty(lex)
