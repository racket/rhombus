// 13.2.5.65 DOCTYPE system identifier (double-quoted) state
state doctype_system_identifier_double_quoted_state(lex)
| Char"\"":
    after_doctype_system_identifier_state
| Char"\0":
    parse_error(lex, #'unexpected_null_character)
