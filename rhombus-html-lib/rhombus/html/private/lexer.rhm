    set_doctype_force_quirks(lex)
    reconsume_in(lex, bogus_doctype_state)

// 13.2.5.64 Before DOCTYPE system identifier state
state before_doctype_system_identifier_state(lex)
| Char"\t" || Char"\n" || Char"\f" || Char" ":
    before_doctype_system_identifier_state
| Char"\"":
