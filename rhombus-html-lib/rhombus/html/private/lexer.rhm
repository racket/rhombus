// 13.2.5.67 After DOCTYPE system identifier state
state after_doctype_system_identifier_state(lex)
| Char"\t" || Char"\n" || Char"\f" || Char" ":
    after_doctype_system_identifier_state
| Char">":
    emit_current_doctype(lex)
    data_state
| Port.eof:
    parse_error(lex, #'eof_in_doctype)
    set_doctype_force_quirks(lex)
    emit_current_doctype(lex)
    emit(lex, Token.EOF())
    #false
| c:
    parse_error(lex, #'unexpected_character_after_doctype_system_identifier)
    reconsume_in(lex, bogus_doctype_state)

// 13.2.5.68 Bogus DOCTYPE state
state bogus_doctype_state(lex)
| Char">":
    emit_current_doctype(lex)
    data_state
| Char"\0":
    parse_error(lex, #'unexpected_null_character)
    bogus_doctype_state
| Port.eof:
    emit_current_doctype(lex)
    emit(lex, Token.EOF())
    #false
| c:
    bogus_doctype_state

// 13.2.5.69 CDATA section state
state cdata_section_state(lex)
| Char"]":
    cdata_section_bracket_state
| Port.eof:
    parse_error(lex, #'eof_in_cdata)
    emit(lex, Token.EOF())
    #false
| c :: Char:
    emit(lex, Token.Character(c))
    cdata_section_state

// 13.2.5.70 CDATA section bracket state
state cdata_section_bracket_state(lex)
| Char"]":
    cdata_section_end_state
| c:
    emit(lex, Token.Character(Char"]"))
    reconsume_in(lex, cdata_section_state)

// 13.2.5.71 CDATA section end state
state cdata_section_end_state(lex)
| Char"]":
    emit(lex, Token.Character(Char"]"))
    cdata_section_end_state
| Char">":
    data_state
| c:
    emit(lex, Token.Character(Char"]"))
    emit(lex, Token.Character(Char"]"))
    reconsume_in(lex, cdata_section_state)


// ----------------------------------------------------------------------------
// Character reference states (13.2.5.72-80)
//
// The full ~2231-entry named-character-reference table lives in
// `entities.rhm`, generated from https://html.spec.whatwg.org/entities.json.
// We bind it to a local `NAMED_ENTITIES` here. It really is just a
// `Map(String, String)`; everything below treats it that way.

def NAMED_ENTITIES :~ Map.of(String, String) = entities.NAMED_ENTITIES

// 13.2.5.72 Character reference state
fun character_reference_state(lex :~ Lexer):
  lex.temp_buffer := "&"
  let c = lex.consume()
  cond
  | c is_a Char && is_ascii_alphanumeric(c):
      lex.push_back(c)
      named_character_reference_state
  | c == Char"#":
      lex.temp_buffer := lex.temp_buffer ++ "#"
      numeric_character_reference_state
  | ~else:
      flush_code_points_consumed_as_character_reference(lex)
      cond
      | c is_a Char:
          lex.push_back(c)
          lex.return_state
      | ~else:  // Port.eof
          lex.return_state

// 13.2.5.73 Named character reference state
//
// The spec text:
//   "Consume the maximum number of characters possible, where the consumed
//    characters are one of the identifiers in the first column of the named
//    character references table. Append each character to the temporary
//    buffer when it's consumed."
//
// We implement this by reading characters while *some* known entity name
// still has the accumulated characters as a prefix. After we've gone past
// any prefix, find the longest *exact* known prefix and "push back" the
// extra characters we read.
fun named_character_reference_state(lex :~ Lexer):
  // Read while the accumulated string (after `&`) is a strict prefix of
  // some known name OR is itself a known name. Also bail out if we see a
  // non-alphanumeric/non-`;` character.
  let collected:
    recur loop(acc :: String = ""):
      let nxt = lex.consume()
      cond
      | nxt is_a Char && (is_ascii_alphanumeric(nxt) || nxt == Char";"):
          let acc2 = acc ++ to_string(nxt)
          cond
          | acc2 in NAMED_ENTITY_PREFIXES:
              if nxt == Char";"
              | block:
                  acc2
              | block:
                  loop(acc2)
          | ~else:
              // No entity name extends acc2; we've gone too far, push back
              // the most recent char.
              lex.push_back(nxt)
              acc
      | ~else:
          cond
          | nxt is_a Char: lex.push_back(nxt)
          | ~else: #void
          acc
  // Now find the longest match: prefer `acc` itself, else any prefix.
  let match_name:
    recur shrink(s :~ String = collected):
      cond
      | s == "": #false
      | s in NAMED_ENTITIES: s
      | ~else: shrink(s.substring(0, String.length(s) - 1))
  cond
  | match_name:
      // Determine if next char is in attribute-value context with weird
      // semicolon-omission rules.
      let last_consumed = (match_name :: String)[String.length(match_name :: String) - 1]
      let was_with_semi = (last_consumed == Char";")
      // The "next input character" in the spec sense is the first
      // character after the matched portion, which is either:
      //   - the first char of `extras` (collected beyond match_name), or
      //   - a peek into the actual port if no extras
      let next_is_eq_or_alpha:
        let mlen = String.length(match_name :: String)
        let clen = String.length(collected :: String)
        let nxt:
          cond
          | mlen < clen: (collected :: String)[mlen]
          | ~else:
              let s = lex.peek_string(1)
              cond
              | s == "": #false
              | ~else: s[0]
        cond
        | nxt is_a Char: (nxt == Char"=") || is_ascii_alphanumeric(nxt)
        | ~else: #false
      cond
      | (!was_with_semi) && consumed_as_part_of_attribute(lex) && next_is_eq_or_alpha:
          // historical: don't treat as char ref
          let mlen = String.length(match_name :: String)
          let clen = String.length(collected :: String)
          let extras = (collected :: String).substring(mlen, clen)
          lex.push_back_string(extras)
          lex.temp_buffer := "&" ++ match_name
          flush_code_points_consumed_as_character_reference(lex)
          lex.return_state
      | ~else:
          if !was_with_semi
          | parse_error(lex, #'missing_semicolon_after_character_reference)
          | #void
          let mlen = String.length(match_name :: String)
          let clen = String.length(collected :: String)
          let extras = (collected :: String).substring(mlen, clen)
          lex.push_back_string(extras)
          lex.temp_buffer := NAMED_ENTITIES[match_name :: String]
          flush_code_points_consumed_as_character_reference(lex)
          lex.return_state
  | ~else:
      // No match. Flush "&" + collected, then go to ambiguous-ampersand if
      // collected ends in alphanumeric.
      lex.temp_buffer := "&" ++ collected
      flush_code_points_consumed_as_character_reference(lex)
      ambiguous_ampersand_state

// 13.2.5.74 Ambiguous ampersand state
state ambiguous_ampersand_state(lex)
| Char";":
    parse_error(lex, #'unknown_named_character_reference)
    reconsume_in(lex, lex.return_state)
| c :: Char:
    cond
    | is_ascii_alphanumeric(c):
        cond
        | consumed_as_part_of_attribute(lex):
            append_to_current_attribute_value(lex, c)
        | ~else:
            emit(lex, Token.Character(c))
        ambiguous_ampersand_state
    | ~else:
        reconsume_in(lex, lex.return_state)
| Port.eof:
    reconsume_in(lex, lex.return_state)

// 13.2.5.75 Numeric character reference state
def NUMERIC_REF_CODE = Box(0)

state numeric_character_reference_state(lex)
| Char"x" || Char"X":
    temp_buffer_append(lex, lex.last_char :: Char)
    NUMERIC_REF_CODE.value := 0
    hexadecimal_character_reference_start_state
| c:
    NUMERIC_REF_CODE.value := 0
    reconsume_in(lex, decimal_character_reference_start_state)

// 13.2.5.76 Hexadecimal character reference start state
state hexadecimal_character_reference_start_state(lex)
| c :: Char:
    cond
    | is_ascii_hex_digit(c):
        reconsume_in(lex, hexadecimal_character_reference_state)
    | ~else:
        parse_error(lex, #'absence_of_digits_in_numeric_character_reference)
        flush_code_points_consumed_as_character_reference(lex)
        reconsume_in(lex, lex.return_state)
| Port.eof:
    parse_error(lex, #'absence_of_digits_in_numeric_character_reference)
    flush_code_points_consumed_as_character_reference(lex)
    lex.return_state

// 13.2.5.77 Decimal character reference start state
state decimal_character_reference_start_state(lex)
| c :: Char:
    cond
    | is_ascii_digit(c):
        reconsume_in(lex, decimal_character_reference_state)
    | ~else:
        parse_error(lex, #'absence_of_digits_in_numeric_character_reference)
        flush_code_points_consumed_as_character_reference(lex)
        reconsume_in(lex, lex.return_state)
| Port.eof:
    parse_error(lex, #'absence_of_digits_in_numeric_character_reference)
    flush_code_points_consumed_as_character_reference(lex)
    lex.return_state

// 13.2.5.78 Hexadecimal character reference state
state hexadecimal_character_reference_state(lex)
| c :: Char:
    let n = c.to_int()
    cond
    | is_ascii_digit(c):
        NUMERIC_REF_CODE.value := NUMERIC_REF_CODE.value * 16 + (n - 0x30)
        hexadecimal_character_reference_state
    | (0x41 <= n) && (n <= 0x46):
        NUMERIC_REF_CODE.value := NUMERIC_REF_CODE.value * 16 + (n - 0x41 + 10)
        hexadecimal_character_reference_state
    | (0x61 <= n) && (n <= 0x66):
        NUMERIC_REF_CODE.value := NUMERIC_REF_CODE.value * 16 + (n - 0x61 + 10)
        hexadecimal_character_reference_state
    | c == Char";":
        numeric_character_reference_end_state
    | ~else:
        parse_error(lex, #'missing_semicolon_after_character_reference)
        reconsume_in(lex, numeric_character_reference_end_state)
| Port.eof:
    parse_error(lex, #'missing_semicolon_after_character_reference)
    numeric_character_reference_end_state

// 13.2.5.79 Decimal character reference state
state decimal_character_reference_state(lex)
| c :: Char:
    let n = c.to_int()
    cond
    | is_ascii_digit(c):
        NUMERIC_REF_CODE.value := NUMERIC_REF_CODE.value * 10 + (n - 0x30)
        decimal_character_reference_state
    | c == Char";":
        numeric_character_reference_end_state
    | ~else:
        parse_error(lex, #'missing_semicolon_after_character_reference)
        reconsume_in(lex, numeric_character_reference_end_state)
| Port.eof:
    parse_error(lex, #'missing_semicolon_after_character_reference)
    numeric_character_reference_end_state

// 13.2.5.80 Numeric character reference end state
fun numeric_character_reference_end_state(lex :~ Lexer):
  let code:
    let raw = NUMERIC_REF_CODE.value
    cond
    | raw == 0:
        parse_error(lex, #'null_character_reference)
        0xFFFD
    | raw > 0x10FFFF:
        parse_error(lex, #'character_reference_outside_unicode_range)
        0xFFFD
    | (0xD800 <= raw) && (raw <= 0xDFFF):
        parse_error(lex, #'surrogate_character_reference)
        0xFFFD
    | ~else:
        // A few more spec-mandated parse-error checks (noncharacters, C0
        // controls, etc.) are skipped for brevity; we still apply the C1
        // remap below.
        raw
  let final_code:
    // Spec also remaps a handful of legacy code points (e.g. 0x80 -> 0x20AC)
    // We include the table for completeness.
    let remap = {0x80: 0x20AC, 0x82: 0x201A, 0x83: 0x0192, 0x84: 0x201E,
                 0x85: 0x2026, 0x86: 0x2020, 0x87: 0x2021, 0x88: 0x02C6,
                 0x89: 0x2030, 0x8A: 0x0160, 0x8B: 0x2039, 0x8C: 0x0152,
                 0x8E: 0x017D, 0x91: 0x2018, 0x92: 0x2019, 0x93: 0x201C,
                 0x94: 0x201D, 0x95: 0x2022, 0x96: 0x2013, 0x97: 0x2014,
                 0x98: 0x02DC, 0x99: 0x2122, 0x9A: 0x0161, 0x9B: 0x203A,
                 0x9C: 0x0153, 0x9E: 0x017E, 0x9F: 0x0178}
    cond
    | remap.has_key(code): remap[code]
    | ~else: code
  lex.temp_buffer := to_string(Char.from_int(final_code))
  flush_code_points_consumed_as_character_reference(lex)
  lex.return_state

// ----------------------------------------------------------------------------
// Trampoline driver

fun run(lex :~ Lexer, start) :~ values(List, List):
  recur loop(state = start):
    let next = state(lex)
    if next
    | loop(next)
    | values(lex.tokens, lex.errors)
