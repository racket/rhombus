    reconsume_in(lex, bogus_doctype_state)

// 13.2.5.63 After DOCTYPE system keyword state
state after_doctype_system_keyword_state(lex)
| Char"\t" || Char"\n" || Char"\f" || Char" ":
    before_doctype_system_identifier_state
| Char"\"":
    parse_error(lex, #'missing_whitespace_after_doctype_system_keyword)
    set_doctype_system_id_empty(lex)
    doctype_system_identifier_double_quoted_state
| Char"'":
    parse_error(lex, #'missing_whitespace_after_doctype_system_keyword)
    set_doctype_system_id_empty(lex)
    doctype_system_identifier_single_quoted_state
| Char">":
    parse_error(lex, #'missing_doctype_system_identifier)
