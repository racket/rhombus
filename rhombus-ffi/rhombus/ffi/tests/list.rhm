#lang rhombus/static
import:
  ffi open

block:
  let p = cast ~from (list_t(int_t)) ~to (ptr_t) [1, 2, 3]
  check cast ~to (list_t(int_t) ~length 3) p ~is [1, 2, 3]
  check (cast (int_t*)p)[0] ~is 1
  check (cast (int_t*)p)[2] ~is 3

block:
  let p = cast ~from (array_t(int_t)) ~to (ptr_t) Array(-1, -2, -3, -4)
  check cast ~to (array_t(int_t) ~length 4) p ~is_now Array(-1, -2, -3, -4)
  check (cast (int_t*)p)[0] ~is -1
  check (cast (int_t*)p)[2] ~is -3
