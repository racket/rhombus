#lang rhombus/static
import:
  ffi open
  ffi/finalize
  rhombus/memory

foreign.linker libc:
  ~lib: Lib.load(#false)

libc.fun c_free(ptr_t) :: void_t:
  ~c_id: free
  ~wrap: finalize.deallocator()

libc.fun c_malloc(size_t) :: ptr_t:
  ~c_id: malloc
  ~wrap: finalize.allocator(c_free)

def p1 = c_malloc(10)
c_free(p1)

for (j in 0..10):
  for (i in 0..1000):
    c_malloc(10)
  memory.gc()
