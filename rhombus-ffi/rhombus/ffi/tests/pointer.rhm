#lang rhombus/static
import:
  ffi open

check sizeof(int_t*) ~is sizeof(ptr_t)
check sizeof(int_t* /gcable)  ~is sizeof(ptr_t)
check malloc(10) ~is_a ptr_t
check malloc(10) ~is_a ptr_t/gcable
check malloc ~immobile (10) ~is_a ptr_t
check malloc ~immobile (10) ~is_a ptr_t/gcable

block:
  let p_i = new int_t
  check p_i ~is_a ptr_t

  let p_is = new int_t[5+5]
  check p_is ~is_a ptr_t

  check mem *(int_t*)p_i := 10 ~is #void
  check mem *(int_t*)p_i ~is 10

  check mem *p_i := 100 ~is #void
  check mem *p_i ~is 100

  check mem p_i[0] := 20 + 30 ~is #void
  check mem p_i[0] ~is 50
  check mem p_is[0] := 1234 + (1234 bits.(<<) 16) ~is #void
  check mem p_is[0] ~is 1234 + (1234 bits.(<<) 16)
  check mem (cast (short_t *) p_is)[0] ~is 1234

  check mem p_is[1] := 345 ~is #void
  check mem (mem &p_is[1])[0] ~is 345

  check mem *(p_i) := 20 + 30 ~is #void
  check mem *(p_i) ~is 50
  check mem *(p_is) := 1234 + (1234 bits.(<<) 16) ~is #void
  check mem *(p_is) ~is 1234 + (1234 bits.(<<) 16)
  check mem *(cast (short_t *) p_is) ~is 1234

  check new ~immobile int_t[10] ~is_a ptr_t
  check new ~traced int_t[10] ~is_a ptr_t
  check new ~traced_immobile int_t[10] ~is_a ptr_t

block:
  foreign.type whatever_t:
    ~extends: int_t
  let p1 = malloc ~as whatever_t* (10)
  check p1 ~is_a foreign.type whatever_t*
  check p1 ~is_a foreign.type int_t*
  check mem *(int_t *)p1 := 11 ~is #void
  check mem *(int_t *)p1 ~is 11
  check cast ~from (whatever_t*) ~to (ptr_t) p1 ~is_a ptr_t
  check cast ~from (whatever_t*) ~to (ptr_t) (new int_t) ~throws "value does not match type"

block:
  let p = new double_t[3]
  check p ~is_a ptr_t
  check p ~is_a foreign.type double_t*
  check p ~is_a foreign.type double_t[100]
  check mem p[0] := 10.25 ~is #void
  check mem p[0] ~is 10.25
  check mem p[-1] ~throws "does not satisfy annotation"
  check mem p[4] ~throws "does not satisfy annotation"

check 10 is_a ptr_t ~is #false
check new int_t[1] is_a ptr_t ~is #true
check new int_t[1] is_a ptr_t/gcable ~is #true
block:
  let p = new ~manual int_t[1]
  check p is_a ptr_t ~is #true
  check p is_a ptr_t/gcable ~is #false
  free(p)

check:
  new int_t* ~is_a foreign.type int_t * *
  new int_t** ~is_a foreign.type int_t * * *
  new int_t*[3] ~is_a foreign.type int_t * *
  new int_t*[3+1] ~is_a foreign.type int_t * *
  (new int_t*) is_a (foreign.type int_t*) ~is #false
  (new int_t*) is_a (foreign.type int_t**) ~is #true
  (new int_t**) is_a (foreign.type int_t * /gcable * /gcable *) ~is #true

check mem *(int_t *)0 := "10" ~throws "value does not satisfy annotation"
check mem *(int_t *)(new int_t) := "10" ~throws "value does not match type"
check mem (new int_t)["x"] ~throws "value does not satisfy annotation"
check mem (new int_t)["x"] := 10 ~throws "value does not satisfy annotation"

block:
  let ppi = new ~traced int_t*
  block:
    let pi = new int_t
    mem pi[0] := 17
    mem ppi[0] := pi
  check mem (mem ppi[0])[0] ~is 17
  check (mem (mem ppi[0])[0]) < mem (mem ppi[0])[0] ~is #false

  let pppi = new ~traced int_t**
  mem pppi[0] := ppi
  check mem (mem (mem pppi[0])[0])[0] ~is 17
