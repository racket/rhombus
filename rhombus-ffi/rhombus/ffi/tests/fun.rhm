#lang rhombus/static
import:
  ffi open

def c_lib = Lib.load(#false)!!

foreign.def strlen :: (string_t -> int_t: ~atomic):
  ~lib: c_lib

def sprintf_int_dbl:
  cast ((bytes_ptr_t, string_t, ~varargs, int_t, double_t) -> void_t) c_lib.find("sprintf")

check strlen("apple") ~is 5

def bstr = Bytes.make(100)
sprintf_int_dbl(bstr, "hi %d %f", 10, 35.25)
check (cast ~from (bytes_ptr_t) ~to (string_t) bstr)!!.starts_with("hi 10 35.25") ~is #true

foreign.def sprintf_int_int :: (bytes_ptr_t, string_t, ~varargs, int_t, int_t) -> void_t:
  ~lib: c_lib
  ~c_id: sprintf

check sprintf_int_int(bstr, "hi %d %f", 1.0, 2) ~throws "argument does not match type"
check sprintf_int_int(bstr, "hi %d %f", 1, 2.0) ~throws "argument does not match type"

foreign.linker libc:
  ~lib: c_lib
  ~default_fail: fun (x) :: ((~any) -> Never): fun (a, ...): error("not available")

foreign.type Rect_t
libc.fun sprintf_rectptrptr(bytes_ptr_t, string_t, ~varargs, Rect_t**) :: void_t:
  ~c_id: sprintf
check sprintf_rectptrptr(bstr, "hi %d %f", 1) ~throws values("argument does not match type",
                                                             "Rect_t**")

libc.fun sprintf_zeros(bytes_ptr_t, string_t, ~varargs, a :: int_t = 0, int_t = a) :: void_t:
  ~c_id: sprintf
sprintf_zeros(bstr, "hi %d %d")
check cast ~from (bytes_ptr_t) ~to (string_t) bstr ~is "hi 0 0"

libc.fun sprintf_void(bytes_ptr_t, string_t, ~varargs) :: (vd :: void_t):
  ~c_id: sprintf
  ~abi: default_abi

libc.fun sprintf_errno(bytes_ptr_t, string_t, ~varargs) :: (void_t, ~errno):
  ~c_id: sprintf
  ~abi: system_case os
        | windows: default_abi
        | ~else: stdcall_abi
block:
  let (v, n) = sprintf_errno(bstr, "hello")
  check v ~is #void
  check n ~is_a Int

foreign.fun sprintf_noisy(bytes_ptr_t, string_t, ~varargs) :: void_t:
  ~lib: c_lib
  ~c_id: sprintf
  "noisy"
check sprintf_noisy(bstr, "hello") ~is "noisy"

libc.fun sprintf_errno2(bytes_ptr_t, string_t, ~varargs) :: (vd :: void_t, e :: ~errno):
  ~c_id: sprintf
  [vd, e]
check sprintf_errno2(bstr, "hello") ~matches [#void, _ :: Int]
libc.fun nonesuch(int_t) :: int_t
check nonesuch(0) ~throws "not available"
