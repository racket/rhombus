check crypto_hash.sha256_bytes(#"apple") ~is_now #":{\323\3426\n=)\356\2446\374\373~D\3075\321\27\304-\34\0305B\vk\231B\335O\e"
check crypto_hash.sha256(#"apple") ~is "3a7bd3e2360a3d29eea436fcfb7e44c735d117c42d1c1835420b6b9942dd4f1b"
